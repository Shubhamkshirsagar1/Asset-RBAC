{
  "name": "nodejs-rbac",
  "version": "2.0.0",
  "description": "Dynamic multi-tenant RBAC+ABAC platform (Postgres, routes->controllers->services).",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node src/db/migrate.js up",
    "db:migrate:down": "node src/db/migrate.js down",
    "seed": "node src/seed.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "umzug": "^3.8.1"
  },
  "license": "MIT"
}
